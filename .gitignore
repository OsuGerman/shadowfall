# ============================================================
# AI-GENERIERTE AUDIO-ARTEFAKTE
# ============================================================
# Update: Audio-Files sind jetzt MIT committet (Repo ist self-contained,
# Game ist sofort spielbar nach git clone). Re-Generation via
# tools/voice_gen.py + tools/sfx_gen.py weiterhin möglich.
# .wav bleibt geblockt (nur Zwischenformate, wir nutzen mp3).
sounds/voice/**/*.wav
sounds/sfx/generated/**/*.wav

